<%= form_with(model: yard) do |form| %>
  <% if yard.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(yard.errors.count, "error") %> prohibited this yard from being saved:</h2>

      <ul>
        <% yard.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :rows, style: "display: block" %>
    <%= form.number_field :rows %>
  </div>

  <div>
    <%= form.label :columns, style: "display: block" %>
    <%= form.number_field :columns %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
